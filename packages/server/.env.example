# ============================================
# PrivShare Server Environment Configuration
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Client Configuration
CLIENT_URL=http://localhost:3000

# JWT Configuration (Change in production!)
JWT_SECRET=privshare-dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# Payload Limits
MAX_JSON_PAYLOAD=10kb

# Production URLs (set in production)
# PRODUCTION_URL=https://privshare.example.com
