{
  "name": "@privshare/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PrivShare Client - React 19 Frontend with WebAssembly Integration",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:sri": "node ../../scripts/generate-sri-hash.js",
    "build:validate": "node ../../scripts/validate-sri.js --strict",
    "build:production": "npm run build && npm run build:sri && npm run build:validate",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "security:check": "npm run build:validate",
    "security:fix": "node ../../scripts/validate-sri.js --fix"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.28.0",
    "pdfjs-dist": "^4.0.379",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
